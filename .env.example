# InkVerse 环境变量模板
# 复制此文件为 .env 并按需填入；未配置的项会落回 config.py 中的默认值。

# ── API Keys ────────────────────────────────────────────────────────────────
# 阿里百炼 API Key（推荐，覆盖评分/提示词/图像 API）
# 获取地址：https://bailian.console.aliyun.com/ -> API Key 管理
DASHSCOPE_API_KEY=your_dashscope_key_here

# DeepSeek API Key（可选，仅在 config.py 中切换 LLM_BACKEND="deepseek" 时使用）
# 获取地址：https://platform.deepseek.com/ -> API Keys
DEEPSEEK_API_KEY=your_deepseek_key_here

# 智谱 AI API Key（可选，eval_poem 跨家族 3 评委 / 切 LLM_BACKEND="zhipu" 时使用）
# 获取地址：https://open.bigmodel.cn/ -> API Keys
ZHIPU_API_KEY=your_zhipu_key_here

# Moonshot AI / Kimi API Key（可选，eval_poem 加 moonshot-v1-32k 作中文古典强评委）
# 注意：kimi-latest 已弃用；kimi-k2.6/k2.7 为 reasoning model 强制 temperature=1，不适合 BWS 评分
# 评分任务推荐使用经典 moonshot-v1-32k（非 reasoning，支持 temperature 调节）
# 获取地址：https://platform.moonshot.cn/ -> API Keys
MOONSHOT_API_KEY=your_moonshot_key_here

# ── 本地模型路径（可选）─────────────────────────────────────────────────────
# 仅在你希望启用本地 LLM / LoRA / Z-Image 时填写。
# 未配置或路径不存在时，UI 会自动隐藏对应的"本地"选项，仅保留 API 后端，
# 应用照样可跑（推荐面试官/审阅者使用纯 API 模式）。
#
# BASE_MODEL_PATH=D:\AI_Models\Qwen2.5-1.5B-Instruct
# LORA_PATH=./models/poetry_lora
# ZIMAGE_PATH=D:\AI_Models\z_image_fp8_full
